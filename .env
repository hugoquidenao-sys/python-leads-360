# Python Leads 360 - Variables de Entorno

# OpenAI API Key (requerido para generación de correos y propuestas)
OPENAI_API_KEY=
# Google Maps API Key (requerido para búsqueda de empresas)
GOOGLE_MAPS_API_KEY=

# Configuración de la base de datos
DATABASE_PATH=data/leads360.db

# Directorio de salida
OUTPUT_DIR=outputs/

# Configuración de scraping
SCRAPING_TIMEOUT=15
SCRAPING_MAX_RETRIES=3
SCRAPING_DELAY=1.5

# Configuración de IA
OPENAI_MODEL=gpt-4o-mini
MAX_COMPANIES_PER_SEARCH=20
